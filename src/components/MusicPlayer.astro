---
// 音乐播放器 — 修改 PLAY 对象即可切换歌单/平台
// server: netease | tencent | kugou | xiami | baidu
// type:   playlist | album | song | artist
---

<div class="sidebar-music bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5">
  <h2 class="text-sm font-semibold mb-4 text-gray-900 dark:text-gray-100">
    🎵 听听音乐
  </h2>
  <div class="sidebar-music-container"></div>
</div>

<style is:inline>
  #sidebar-drawer .sidebar-music { display: none; }

  .dark .aplayer {
    background: var(--color-card-dark, #1e1e2e) !important;
    border-color: rgba(255,255,255,0.06) !important;
  }
  .dark .aplayer .aplayer-info .aplayer-music { color: #e5e5e5 !important; }
  .dark .aplayer .aplayer-info .aplayer-music .aplayer-author { color: #999 !important; }
  .dark .aplayer .aplayer-list ol li {
    background: transparent !important;
    border-top-color: rgba(255,255,255,0.04) !important;
  }
  .dark .aplayer .aplayer-list ol li:hover { background: rgba(255,255,255,0.05) !important; }
  .dark .aplayer .aplayer-list ol li.aplayer-list-light { background: rgba(255,255,255,0.08) !important; }
  .dark .aplayer .aplayer-list ol li .aplayer-list-cur { color: var(--color-primary, #6366f1) !important; }
  .dark .aplayer .aplayer-list ol li .aplayer-list-author { color: #777 !important; }
  .dark .aplayer .aplayer-lrc { color: #ccc !important; }
  .dark .aplayer .aplayer-lrc p.aplayer-lrc-current { color: var(--color-primary, #6366f1) !important; }
  .dark .aplayer .aplayer-lrc:before,
  .dark .aplayer .aplayer-lrc:after {
    background: linear-gradient(to bottom, var(--color-card-dark, #1e1e2e), transparent) !important;
  }
  .dark .aplayer .aplayer-icon,
  .dark .aplayer .aplayer-icon:hover { color: #ccc !important; }
  .dark .aplayer .aplayer-volume-wrap .aplayer-volume-bar { background: rgba(255,255,255,0.1) !important; }
  .sidebar-music .aplayer { border-radius: 10px; margin: 0; }
</style>

<script is:inline>
  (function() {
    var PLAY = {
      server: 'netease',
      type: 'playlist',
      id: '7455414198',
    };

    var CSS_URL = 'https://cdn.jsdelivr.net/npm/aplayer@1.10.1/dist/APlayer.min.css';
    var APLAYER_URL = 'https://cdn.jsdelivr.net/npm/aplayer@1.10.1/dist/APlayer.min.js';
    var METING_URL = 'https://cdn.jsdelivr.net/npm/meting@2/dist/Meting.min.js';

    function loadCSS(url) {
      if (document.querySelector('link[href="' + url + '"]')) return;
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = url;
      document.head.appendChild(link);
    }

    function loadJS(url, callback) {
      if (document.querySelector('script[src="' + url + '"]')) { if (callback) callback(); return; }
      var s = document.createElement('script');
      s.src = url;
      s.onload = callback;
      s.onerror = function() { console.warn('Failed to load:', url); };
      document.head.appendChild(s);
    }

    var initialized = false;

    function initPlayer() {
      var containers = document.querySelectorAll('.sidebar-music-container');
      if (!containers.length || initialized) return;
      initialized = true;

      loadCSS(CSS_URL);

      loadJS(APLAYER_URL, function() {
        loadJS(METING_URL, function() {
          // 此时 APlayer + MetingJS 都已就绪，手动创建 meting-js 触发初始化
          containers.forEach(function(el) {
            // 跳过移动端抽屉中的（display:none）
            if (el.closest('#sidebar-drawer')) return;

            var meting = document.createElement('meting-js');
            meting.setAttribute('server', PLAY.server);
            meting.setAttribute('type', PLAY.type);
            meting.setAttribute('id', PLAY.id);
            meting.setAttribute('fixed', 'false');
            meting.setAttribute('autoplay', 'false');
            meting.setAttribute('loop', 'all');
            meting.setAttribute('order', 'random');
            meting.setAttribute('preload', 'auto');
            meting.setAttribute('volume', '0.4');
            meting.setAttribute('lrc-type', '1');
            meting.setAttribute('list-folded', 'true');
            meting.setAttribute('list-max-height', '180px');
            meting.setAttribute('mutex', 'true');
            el.appendChild(meting);
          });
        });
      });
    }

    initPlayer();

    // view transition 导航后重建
    document.addEventListener('astro:page-load', function() {
      // 清理旧播放器
      document.querySelectorAll('.sidebar-music-container meting-js').forEach(function(el) {
        el.remove();
      });
      initialized = false;
      initPlayer();
    });
  })();
</script>
