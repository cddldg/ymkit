---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<nav class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5">
  <h2 class="text-sm font-semibold mb-3 text-gray-900 dark:text-gray-100">
    目录
  </h2>
  {filtered.length > 0 ? (
    <ul class="space-y-1">
      {filtered.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class={`block text-xs py-1 transition-colors hover:text-primary text-gray-500 dark:text-gray-400 ${
              heading.depth === 3 ? 'pl-4' : ''
            }`}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="text-xs text-gray-400 dark:text-gray-500">暂无目录</p>
  )}
</nav>
