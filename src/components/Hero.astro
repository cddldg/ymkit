  tool: 'M11.42 15.17l-5.384 5.384a2.025 2.025 0 01-2.864-2.864l5.384-5.384m2.864 2.864L15 12m0 0l3.72-3.72M15 12l-3.72 3.72M15 12H9m6 6v-6m0 0V9m0 6h-6',
  ai: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z',
};
---

<section class="hero" aria-label="网站介绍">
  <!-- CSS 渐变光斑背景 -->
  <div class="hero-bg">
    <div class="hero-blob blob-1"></div>
    <div class="hero-blob blob-2"></div>
    <div class="hero-blob blob-3"></div>
  </div>

  <!-- 内容 -->
  <div class="hero-content">
    <!-- 标题 -->
    <div class="hero-text">
      <h1 class="hero-title">{SITE_TITLE}</h1>
      <p class="hero-desc">{SITE_DESCRIPTION}</p>
    </div>

    <!-- 统计 -->
    <div class="hero-stats">
      <a href="/archives" class="hero-stat">
        <span class="hero-stat-num">{totalCount}</span>
        <span class="hero-stat-label">文章</span>
      </a>
      <span class="hero-stat-divider"></span>
      <a href="/tags" class="hero-stat">
        <span class="hero-stat-num">{CATEGORY_CARDS.length}</span>
        <span class="hero-stat-label">分类</span>
      </a>
    </div>

    <!-- 分类卡片 -->
    <div class="hero-cards">
      {CATEGORY_CARDS.map((card) => (
        <a href={card.href} class="hero-card group">
          <div class="hero-card-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconMap[card.icon] || iconMap.plugin} />
            </svg>
          </div>
          <div class="hero-card-text">
            <span class="hero-card-label">{card.label}</span>
            <span class="hero-card-desc">{card.description}</span>
          </div>
          <svg class="hero-card-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    margin-bottom: 2.5rem;
    /* 渐变背景兜底 */
    background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
  }

  :root.dark .hero {
    background: linear-gradient(135deg, #0f0c29, #1a1a3e, #0d1b2a);
  }

  /* === 光斑动画背景 === */
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }

  .blob-1 {
    width: 400px;
    height: 400px;
    background: #e9536a;
    top: -100px;
    right: -80px;
    animation-name: blob-float-1;
    animation-duration: 12s;
  }

  .blob-2 {
    width: 300px;
    height: 300px;
    background: #4facfe;
    bottom: -80px;
    left: -60px;
    animation-name: blob-float-2;
    animation-duration: 15s;
  }

  .blob-3 {
    width: 250px;
    height: 250px;
    background: #a855f7;
    top: 50%;
    left: 40%;
    animation-name: blob-float-3;
    animation-duration: 18s;
  }

  @keyframes blob-float-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-30px, 20px) scale(1.1); }
    66% { transform: translate(20px, -15px) scale(0.95); }
  }

  @keyframes blob-float-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(25px, -20px) scale(1.05); }
    66% { transform: translate(-15px, 15px) scale(0.9); }
  }

  @keyframes blob-float-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-20px, -25px) scale(1.08); }
  }

  /* === 内容区 === */
  .hero-content {
    position: relative;
    z-index: 1;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .hero-content {
      padding: 3.5rem 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: 4rem 3rem;
      gap: 2.5rem;
    }
  }

  /* === 标题 === */
  .hero-text {
    text-align: center;
    max-width: 600px;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  @media (min-width: 640px) {
    .hero-title {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: 3rem;
    }
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.6;
    margin: 0;
  }

  @media (min-width: 640px) {
    .hero-desc {
      font-size: 1.1rem;
    }
  }

  /* === 统计 === */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .hero-stats {
      gap: 2.5rem;
    }
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    gap: 0.25rem;
    padding: 0.5rem 1rem;
    border-radius: 0.75rem;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.1);
    transition: transform 0.3s, background 0.3s;
  }

  .hero-stat:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,0.14);
  }

  .hero-stat-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1;
  }

  @media (min-width: 640px) {
    .hero-stat-num {
      font-size: 1.75rem;
    }
  }

  .hero-stat-label {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-stat-divider {
    width: 1px;
    height: 2.5rem;
    background: rgba(255,255,255,0.15);
    display: none;
  }

  @media (min-width: 640px) {
    .hero-stat-divider {
      display: block;
    }
  }

  /* === 分类卡片 === */
  .hero-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    max-width: 640px;
  }

  @media (min-width: 640px) {
    .hero-cards {
      flex-direction: row;
      gap: 1rem;
    }
  }

  .hero-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    border-radius: 1rem;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.08);
    text-decoration: none;
    flex: 1;
    transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  @media (min-width: 640px) {
    .hero-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1.5rem 1rem;
      gap: 0.75rem;
    }
  }

  .hero-card:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.2);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
  }

  .hero-card-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    background: rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.3s;
  }

  .hero-card:hover .hero-card-icon {
    background: rgba(233,83,106,0.3);
  }

  .hero-card-icon svg {
    width: 1.25rem;
    height: 1.25rem;
    color: rgba(255,255,255,0.9);
  }

  .hero-card-text {
    flex: 1;
    min-width: 0;
  }

  @media (min-width: 640px) {
    .hero-card-text {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
    }
  }

  .hero-card-label {
    font-size: 0.95rem;
    font-weight: 600;
    color: #ffffff;
    display: block;
    transition: color 0.3s;
  }

  .hero-card:hover .hero-card-label {
    color: rgba(255,255,255,1);
  }

  .hero-card-desc {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.55);
    display: none;
    line-height: 1.4;
  }

  @media (min-width: 640px) {
    .hero-card-desc {
      display: block;
    }
  }

  .hero-card-arrow {
    width: 1rem;
    height: 1rem;
    color: rgba(255,255,255,0.3);
    flex-shrink: 0;
    transition: transform 0.3s, color 0.3s;
  }

  @media (min-width: 640px) {
    .hero-card-arrow {
      display: none;
    }
  }

  .hero-card:hover .hero-card-arrow {
    transform: translateX(3px);
    color: rgba(255,255,255,0.7);
  }
</style>
