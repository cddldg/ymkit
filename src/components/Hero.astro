---
import { SITE_TITLE, SITE_DESCRIPTION, CATEGORY_CARDS } from '../consts';

interface Props {
  collections?: any[];
}

const { collections = [] } = Astro.props;

const totalCount = collections.reduce((sum: number, col: any[]) => sum + col.length, 0);

const iconMap: Record<string, string> = {
