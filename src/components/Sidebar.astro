---
import { getCollection } from 'astro:content';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_AVATAR, SOCIAL_LINKS, SIDEBAR_NOTICES, SIDEBAR_NOTICE_INTERVAL } from '../consts';
import { getWordCount } from '../utils/readingTime';

interface CurrentPost {
  id: string;
  collection: string;
  tags: string[];
}

interface Props {
  currentPost?: CurrentPost;
}

const { currentPost } = Astro.props;

const allPlugins = await getCollection('plugins');
const allTools = await getCollection('tools');
const allAi = await getCollection('ai');

const allPosts = [
  ...allPlugins.map((p) => ({ ...p, collection: 'plugins' as const })),
  ...allTools.map((p) => ({ ...p, collection: 'tools' as const })),
  ...allAi.map((p) => ({ ...p, collection: 'ai' as const })),
];

const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPosts = sorted.length;
let totalWords = 0;
const tagMap = new Map<string, number>();

for (const post of sorted) {
  totalWords += getWordCount(post.body || '');
  for (const tag of post.data.tags || []) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const allTags = Array.from(tagMap.entries()).sort((a, b) => b[1] - a[1]);

const TAG_LIMIT = 15;

const routeMap: Record<string, string> = {
  plugins: '/plugins/',
  tools: '/tools/',
  ai: '/ai/',
};

// 相关推荐逻辑
let recommendedPosts: typeof sorted = [];
let recommendationTitle = '随机推荐';

if (currentPost) {
  // 详情页：根据标签推荐相关文章
  const currentTags = new Set(currentPost.tags);

  // 计算每篇文章与当前文章的标签匹配数
  const scoredPosts = sorted
    .filter((post) => post.id !== currentPost.id) // 排除当前文章
    .map((post) => {
      const matchCount = (post.data.tags || []).filter((tag) => currentTags.has(tag)).length;
      return { ...post, matchCount };
    })
    .filter((post) => post.matchCount > 0) // 只保留有标签匹配的
    .sort((a, b) => b.matchCount - a.matchCount || b.data.date.getTime() - a.data.date.getTime());

  recommendedPosts = scoredPosts.slice(0, 5);

  // 如果有相关文章，显示"相关推荐"
  if (recommendedPosts.length > 0) {
    recommendationTitle = '相关推荐';
  }

  // 如果相关文章不足 5 篇，用随机文章补充
  if (recommendedPosts.length < 5) {
    const existingIds = new Set(recommendedPosts.map((p) => p.id));
    existingIds.add(currentPost.id);
    const additional = [...sorted]
      .filter((post) => !existingIds.has(post.id))
      .sort(() => Math.random() - 0.5)
      .slice(0, 5 - recommendedPosts.length);
    recommendedPosts = [...recommendedPosts, ...additional];
  }
} else {
  // 非详情页：随机推荐
  recommendedPosts = [...sorted].sort(() => Math.random() - 0.5).slice(0, 5);
}

// 侧边栏公告数据
const noticeData = SIDEBAR_NOTICES;
---

<aside class="space-y-6">
  <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-6 text-center">
    <img
      src={SITE_AVATAR}
      alt={SITE_AUTHOR}
      class="w-20 h-20 rounded-full mx-auto mb-3 object-cover ring-2 ring-primary/20"
      width="80"
      height="80"
    />
    <h2 class="font-semibold text-lg">{SITE_AUTHOR}</h2>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{SITE_DESCRIPTION}</p>
    <div class="flex items-center justify-center gap-3 mt-4">
      {SOCIAL_LINKS.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-primary transition-colors"
          title={link.name}
        >
          {link.icon === 'rss' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
          )}
        </a>
      ))}
      <button
        onclick="openDonation()"
        class="text-gray-400 hover:text-cyan-400 transition-colors cursor-pointer bg-transparent border-none p-0 group"
        title="打赏"
      >
        <svg class="w-5 h-5 animate-heart-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
        </svg>
      </button>
    </div>

    <div class="flex items-center justify-center gap-6 mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
      <div class="text-center">
        <div class="font-semibold text-sm">{totalPosts}</div>
        <div class="text-xs text-gray-400">文章</div>
      </div>
      <div class="text-center">
        <div class="font-semibold text-sm">{Math.round(totalWords / 1000)}k</div>
        <div class="text-xs text-gray-400">字数</div>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5" id="sidebar-notice-card" data-notice={JSON.stringify(noticeData)} data-interval={SIDEBAR_NOTICE_INTERVAL}>
    <h2 class="text-sm font-semibold mb-3 text-gray-900 dark:text-gray-100 flex items-center gap-2">
      公告
    </h2>
    <div class="sidebar-notice-bar">
      <span class="sidebar-notice-content" id="sidebarNoticeContent" set:html={noticeData[0]} />
    </div>
  </div>

  {
    allTags.length > 0 && (
      <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5"
        data-sidebar-section="tags"
      >
        <h2 class="text-sm font-semibold mb-3 text-gray-900 dark:text-gray-100">
          标签
        </h2>
        <div class="sidebar-expand-list flex flex-wrap gap-2">
          {allTags.map(([tag, count], i) => (
            <a
              href={`/tags/${tag}`}
              class={`text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-primary hover:text-white dark:hover:bg-primary transition-colors ${
                i >= TAG_LIMIT ? 'hidden sidebar-extra' : ''
              }`}
            >
              {tag}
              <span class="ml-1 opacity-60">({count})</span>
            </a>
          ))}
        </div>
        {
          allTags.length > TAG_LIMIT && (
            <button
              type="button"
              class="sidebar-toggle-btn mt-3 text-xs text-primary hover:underline"
              data-expanded="false"
            >
              显示全部 ({allTags.length})
            </button>
          )
        }
      </div>
    )
  }

  {
    recommendedPosts.length > 0 && (
      <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5">
        <h2 class="text-sm font-semibold mb-4 text-gray-900 dark:text-gray-100">
          {recommendationTitle}
        </h2>
        <div class="space-y-2">
          {recommendedPosts.map((post) => (
            <a
              href={`${routeMap[post.collection]}${post.id}`}
              class="block text-xs text-gray-500 dark:text-gray-400 truncate hover:text-primary transition-colors"
            >
              {post.data.title}
            </a>
          ))}
        </div>
      </div>
    )
  }

  <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5">
    <h2 class="text-sm font-semibold mb-4 text-gray-900 dark:text-gray-100">
      赞赏 & 关注
    </h2>
    <div class="flex gap-3">
      <div class="flex-1 flex flex-col items-center">
        <div class="sidebar-flip-container w-full cursor-pointer" id="sidebar-flip-container" title="点击翻转查看支付宝赞赏">
          <div class="sidebar-flip-inner">
            <div class="sidebar-flip-front flex flex-col items-center">
              <img
                id="sidebar-wx-img"
                src="https://cdn.jsdmirror.cn/gh/cddldg/jst@main/img/20260622180321160.webp"
                alt="微信赞赏码"
                class="w-full rounded-lg aspect-square object-cover"
              />
              <span class="text-xs text-gray-400 mt-1">微信赞赏</span>
            </div>
            <div class="sidebar-flip-back flex flex-col items-center">
              <img
                id="sidebar-zfb-img"
                src="https://cdn.jsdmirror.cn/gh/cddldg/jst@main/img/20260622180325546.webp"
                alt="支付宝赞赏码"
                class="w-full rounded-lg aspect-square object-cover"
              />
              <span class="text-xs text-gray-400 mt-1">支付宝</span>
            </div>
          </div>
        </div>
      </div>
      <div class="flex-1 flex flex-col items-center">
        <img
          id="sidebar-gzh-img"
          src="https://cdn.jsdmirror.cn/gh/cddldg/jst@main/img/20260622180316257.webp"
          alt="公众号"
          class="w-full rounded-lg aspect-square object-cover"
        />
        <span class="text-xs text-gray-400 mt-1">公众号</span>
      </div>
    </div>
  </div>
</aside>

<style is:inline>
  .sidebar-flip-container {
    perspective: 800px;
    aspect-ratio: 1;
  }
  .sidebar-flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.5s ease;
  }
  .sidebar-flip-container.flipped .sidebar-flip-inner {
    transform: rotateY(180deg);
  }
  .sidebar-flip-front,
  .sidebar-flip-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .sidebar-flip-back {
    transform: rotateY(180deg);
  }
  .sidebar-notice-bar {
    min-height: 24px;
    overflow: hidden;
  }
  .sidebar-notice-content {
    display: block;
    font-size: 13px;
    color: #666;
    line-height: 1.5;
    text-align: left;
    transition: opacity 0.3s ease;
  }
  :global(.dark) .sidebar-notice-content {
    color: #999;
  }
  .sidebar-notice-content a {
    color: var(--color-primary, #00b4d8);
    text-decoration: none;
  }
  .sidebar-notice-content a:hover {
    text-decoration: underline;
  }
  .sidebar-notice-content.fading {
    opacity: 0;
  }
</style>

<script is:inline>
  function initSidebarToggles() {
    document.querySelectorAll('.sidebar-toggle-btn').forEach((btn) => {
      if (btn.dataset.initialized) return;
      btn.dataset.initialized = 'true';

      const section = btn.closest('[data-sidebar-section]');
      if (!section) return;
      const list = section.querySelector('.sidebar-expand-list');
      if (!list) return;
      const extraItems = list.querySelectorAll('.sidebar-extra');
      const label = btn.textContent || '';

      btn.addEventListener('click', () => {
        const expanded = btn.dataset.expanded === 'true';
        extraItems.forEach((el) => el.classList.toggle('hidden', expanded));
        btn.dataset.expanded = String(!expanded);
        btn.textContent = expanded ? label : '收起';
      });
    });
  }

  document.addEventListener('astro:page-load', initSidebarToggles);
  initSidebarToggles();
</script>

<script is:inline>
  (function() {
    var sidebarNoticeList = ["<a href='https://www.ymkit.cn' target='_blank'>官网：ymkit.cn</a>"];
    var sidebarNoticeIndex = 0;
    var sidebarNoticeTimer = null;

    function initSidebarNotice() {
      var card = document.getElementById('sidebar-notice-card');
      if (!card || card.dataset.initialized) return;
      card.dataset.initialized = 'true';
      try {
        var raw = card.getAttribute('data-notice');
        if (raw) var parsed = JSON.parse(raw);
        if (parsed && Array.isArray(parsed) && parsed.length) sidebarNoticeList = parsed;
      } catch {}
      var interval = parseInt(card.getAttribute('data-interval') || '3', 10) * 1000;
      if (sidebarNoticeList.length > 1) {
        sidebarNoticeTimer = setInterval(function() {
          var el = document.getElementById('sidebarNoticeContent');
          if (!el) return;
          el.classList.add('fading');
          setTimeout(function() {
            sidebarNoticeIndex = (sidebarNoticeIndex + 1) % sidebarNoticeList.length;
            el.innerHTML = sidebarNoticeList[sidebarNoticeIndex];
            el.classList.remove('fading');
          }, 300);
        }, interval);
      }
    }

    async function fetchSidebarQrData() {
      const defaultImg = {
        wx: 'https://cdn.jsdmirror.cn/gh/cddldg/jst@main/img/20260622180321160.webp',
        zfb: 'https://cdn.jsdmirror.cn/gh/cddldg/jst@main/img/20260622180325546.webp',
        gzh: 'https://cdn.jsdmirror.cn/gh/cddldg/jst@main/img/20260622180316257.webp',
      };
      try {
        const response = await fetch('https://gitee.com/api/v5/repos/dldg/BatchJob/contents/cf.json');
        if (!response.ok) throw new Error('API error');
        const resJson = await response.json();
        const data = JSON.parse(decodeURIComponent(escape(atob(resJson.content))));
        silentUpdateSidebarImg('sidebar-wx-img', (data.img && data.img.wx) || defaultImg.wx);
        silentUpdateSidebarImg('sidebar-zfb-img', (data.img && data.img.zfb) || defaultImg.zfb);
        silentUpdateSidebarImg('sidebar-gzh-img', (data.img && data.img.gzh) || defaultImg.gzh);
      } catch (e) {
        try {
          const proxyUrl = 'https://api.allorigins.win/raw?url=' + encodeURIComponent('https://gitee.com/dldg/BatchJob/raw/master/cf.json');
          const proxyResponse = await fetch(proxyUrl);
          const proxyData = await proxyResponse.json();
          silentUpdateSidebarImg('sidebar-wx-img', (proxyData.img && proxyData.img.wx) || defaultImg.wx);
          silentUpdateSidebarImg('sidebar-zfb-img', (proxyData.img && proxyData.img.zfb) || defaultImg.zfb);
          silentUpdateSidebarImg('sidebar-gzh-img', (proxyData.img && proxyData.img.gzh) || defaultImg.gzh);
        } catch (e2) {}
      }
    }

    function silentUpdateSidebarImg(imgId, newSrc) {
      const img = document.getElementById(imgId);
      if (!img || !newSrc || img.src === newSrc) return;
      let processedSrc = newSrc;
      if (newSrc.includes('gitee.com') && newSrc.includes('/raw/')) {
        processedSrc = newSrc.replace('gitee.com/', 'dldg.gitee.io/').replace('/raw/', '/');
      }
      const tempImg = new Image();
      tempImg.src = processedSrc;
      tempImg.onload = function() { img.src = processedSrc; };
    }

    document.addEventListener('astro:page-load', fetchSidebarQrData);
    fetchSidebarQrData();

    function initSidebarFlip() {
      const container = document.getElementById('sidebar-flip-container');
      if (!container || container.dataset.initialized) return;
      container.dataset.initialized = 'true';
      container.addEventListener('click', () => {
        container.classList.toggle('flipped');
      });
    }

    document.addEventListener('astro:page-load', initSidebarFlip);
    initSidebarFlip();

    document.addEventListener('astro:page-load', initSidebarNotice);
    initSidebarNotice();
  })();
</script>
