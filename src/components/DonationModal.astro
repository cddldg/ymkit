---

---

<div id="donation-modal">
  <div id="donation-backdrop"></div>
  <div id="donation-modal-body">
    <div id="donation-modal-inner">
      <button
        id="donation-close"
        aria-label="关闭"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      <div id="donation-widget-root"></div>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    var widgetLoaded = false;

    function loadWidget() {
      if (widgetLoaded) return;
      widgetLoaded = true;
      var root = document.getElementById('donation-widget-root');
      if (!root) return;
      root.innerHTML = `
        <div class="cyber-card-wrapper" id="cyberCardWrapper">
          <div class="cyber-card">
            <!-- 正面 -->
            <div class="card-face card-front">
              <div class="decor-corner decor-t-l"></div>
              <div class="decor-corner decor-t-r"></div>
              <div class="decor-corner decor-b-l"></div>
              <div class="decor-corner decor-b-r"></div>
              <div class="sound-control" id="soundToggle" onclick="toggleMute(event)" title="开启/关闭未来音效">🔊</div>
              <div class="hint-section">
                <div class="hint-title">🚀 SYSTEM REWARD <span class="tech-tag">[ ONLINE ]</span></div>
                <div class="hint-text" id="hintText">能量注入 ✦ 请作者喝杯冰可乐</div>
              </div>
              <div class="qr-grid">
                <!-- 微信 -->
                <div class="qr-box">
                  <div class="mini-card-container flipped" onclick="triggerMiniFlip(this, event, '#07c160')">
                    <div class="mini-card" style="transform: rotateY(180deg);">
                      <div class="mini-face mini-front">
                        <div class="brand-icon-wrapper icon-wx-front">
                          <svg class="brand-svg" viewBox="0 0 24 24" fill="none">
                            <path d="M8.5 11c-.414 0-.75-.336-.75-.75S8.086 9.5 8.5 9.5s.75.336.75.75-.336.75-.75.75zm5 0c-.414 0-.75-.336-.75-.75s.336-.75.75-.75.75.336.75.75-.336.75-.75.75z" fill="#07C160"/>
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M12.001 2C6.93 2 3 5.372 3 9.75c0 2.473 1.282 4.654 3.321 6.03l-.841 2.508 2.87-1.488c1.1.309 2.27.475 3.483.475.244 0 .487-.007.728-.02-.106-.44-.162-.897-.162-1.368 0-4.045 3.693-7.342 8.23-7.342.115 0 .229.002.343.006C20.47 5.163 16.666 2 12.001 2zm6.666 7.643c-3.791 0-6.884 2.768-6.884 6.16 0 3.391 3.093 6.16 6.884 6.16 1.012 0 1.97-.197 2.833-.548l2.164 1.121-.634-1.892c1.383-1.04 2.247-2.656 2.247-4.437 0-3.392-3.093-6.164-6.884-6.164zm-2.41 4.777c-.31 0-.562-.252-.562-.563 0-.31.252-.562.562-.562s.563.251.563.562c0 .311-.252.563-.563.563zm3.765 0c-.31 0-.563-.252-.563-.563 0-.31.252-.562.563-.562s.562.251.562.562c0 .311-.251.563-.562.563z" fill="#07C160"/>
                          </svg>
                        </div>
                        <div class="tap-to-reveal tap-wx">微信</div>
                      </div>
                      <div class="mini-face mini-back">
                        <div class="laser-scanner"></div>
                        <div class="qr-img-wrapper" id="wxWrapper">
                          <img id="wxImg" class="qr-image" src="https://cdn.jsdmirror.com/gh/cddldg/jst@main/img/20260622180321160.webp" alt="微信" />
                        </div>
                        <div class="zoom-hint-btn" onclick="openZoom('wx', event)" title="全屏放大扫描">🔍</div>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- 支付宝 -->
                <div class="qr-box">
                  <div class="mini-card-container" onclick="triggerMiniFlip(this, event, '#1677ff')">
                    <div class="mini-card">
                      <div class="mini-face mini-front">
                        <div class="brand-icon-wrapper icon-zfb-front">
                          <svg class="brand-svg" viewBox="0 0 24 24" fill="none">
                            <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm3.327 13.911h-2.149c-.218.777-.557 1.543-1.01 2.24-.766-.583-1.61-.954-2.5-1.12.56-.632.993-1.373 1.282-2.176H8.253v-.942h3.428v-1.144H8.729V12h2.952v-1.63H8.35v-.942h3.33V7.81h1.155v1.617h3.344v.942H12.84V12h2.943v.919H12.84v1.144h3.149l-.662 1.848zM12.84 12.919v1.144h-1.002c-.173.498-.415.96-.717 1.38h1.719v-.252l-.001-2.272z" fill="#1677FF"/>
                          </svg>
                        </div>
                        <div class="tap-to-reveal tap-zfb">支付宝</div>
                      </div>
                      <div class="mini-face mini-back">
                        <div class="laser-scanner"></div>
                        <div class="qr-img-wrapper" id="zfbWrapper">
                          <img id="zfbImg" class="qr-image" src="https://cdn.jsdmirror.com/gh/cddldg/jst@main/img/20260622180325546.webp" alt="支付宝" />
                        </div>
                        <div class="zoom-hint-btn" onclick="openZoom('zfb', event)" title="全屏放大扫描">🔍</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <button class="action-btn" id="toGzhBtn" onclick="triggerFlip(event)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                联系作者 ✦ 意见反馈
              </button>
            </div>

            <!-- 背面 -->
            <div class="card-face card-back">
              <div class="decor-corner decor-t-l"></div>
              <div class="decor-corner decor-t-r"></div>
              <div class="decor-corner decor-b-l"></div>
              <div class="decor-corner decor-b-r"></div>
              <div class="hint-section">
                <div class="gzh-title">📢 FEEDBACK & CONTACT <span class="tech-tag pink-tag">[ SECURE ]</span></div>
                <div class="gzh-text">建议/反馈/联系 ✦ 扫码关注</div>
              </div>
              <div class="gzh-qr-box" onclick="openZoom('gzh', event)" title="点击全屏放大">
                <div class="laser-scanner"></div>
                <div class="qr-img-wrapper" id="gzhWrapper" style="width:100%; height:100%;">
                  <img id="gzhImg" class="qr-image" src="https://cdn.jsdmirror.com/gh/cddldg/jst@main/img/20260622180316257.webp" alt="公众号" />
                </div>
                <div class="zoom-hint-btn">🔍</div>
              </div>
              <button class="back-btn" id="backBtn" onclick="triggerFlip(event)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                返回打赏通道
              </button>
            </div>
          </div>
        </div>

        <!-- 全屏放大遮罩 -->
        <div class="zoom-modal" id="zoomModal" onclick="closeZoom()">
          <div class="modal-scanner-view" onclick="event.stopPropagation()">
            <div class="modal-crosshair ch-t-l"></div>
            <div class="modal-crosshair ch-t-r"></div>
            <div class="modal-crosshair ch-b-l"></div>
            <div class="modal-crosshair ch-b-r"></div>
            <img id="zoomModalImg" src="" alt="放大打赏码">
          </div>
          <div class="modal-tip">💡 移动端可长按二维码保存或识别</div>
          <button class="modal-close" onclick="closeZoom()">CLOSE DISCHARGE</button>
        </div>
      `;

      // 初始化功能
      initDonationWidget();
    }

    function initDonationWidget() {
      let isMuted = false;
      let audioCtx = null;

      // 音效合成
      function playCyberSound(type) {
        if (isMuted) return;
        try {
          if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
          if (audioCtx.state === 'suspended') audioCtx.resume();
          const osc = audioCtx.createOscillator();
          const gain = audioCtx.createGain();
          osc.connect(gain);
          gain.connect(audioCtx.destination);
          if (type === 'flip') {
            osc.type = 'triangle';
            osc.frequency.setValueAtTime(280, audioCtx.currentTime);
            osc.frequency.exponentialRampToValueAtTime(70, audioCtx.currentTime + 0.25);
            gain.gain.setValueAtTime(0.12, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.25);
            osc.start();
            osc.stop(audioCtx.currentTime + 0.25);
          } else if (type === 'beep') {
            osc.type = 'sine';
            osc.frequency.setValueAtTime(960, audioCtx.currentTime);
            osc.frequency.setValueAtTime(1440, audioCtx.currentTime + 0.06);
            gain.gain.setValueAtTime(0.06, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.15);
            osc.start();
            osc.stop(audioCtx.currentTime + 0.15);
          }
        } catch (e) {}
      }

      // 粒子效果
      function launchParticles(x, y, color) {
        const root = document.getElementById('donation-widget-root');
        const rootRect = root.getBoundingClientRect();
        const clickX = x - rootRect.left;
        const clickY = y - rootRect.top;
        for (let i = 0; i < 18; i++) {
          const p = document.createElement('div');
          p.className = 'cyber-particle';
          p.style.background = color;
          p.style.left = clickX + 'px';
          p.style.top = clickY + 'px';
          p.style.boxShadow = '0 0 8px ' + color;
          const angle = Math.random() * Math.PI * 2;
          const speed = Math.random() * 90 + 40;
          p.style.setProperty('--tx', Math.cos(angle) * speed + 'px');
          p.style.setProperty('--ty', Math.sin(angle) * speed + 'px');
          root.appendChild(p);
          setTimeout(() => p.remove(), 800);
        }
      }

      window.toggleMute = function(event) {
        event.stopPropagation();
        isMuted = !isMuted;
        document.getElementById('soundToggle').textContent = isMuted ? '🔈' : '🔊';
        if (!isMuted) playCyberSound('beep');
      };

      window.triggerFlip = function(event) {
        event.stopPropagation();
        playCyberSound('flip');
        const wrapper = document.getElementById('cyberCardWrapper');
        wrapper.classList.toggle('flipped');
        wrapper.querySelector('.cyber-card').style.transform = wrapper.classList.contains('flipped') ? 'rotateY(180deg)' : 'rotateY(0deg)';
      };

      window.triggerMiniFlip = function(container, event, particleColor) {
        if (event.target.classList.contains('zoom-hint-btn')) return;
        event.stopPropagation();
        playCyberSound('beep');
        launchParticles(event.clientX, event.clientY, particleColor);
        container.classList.toggle('flipped');
        container.querySelector('.mini-card').style.transform = container.classList.contains('flipped') ? 'rotateY(180deg)' : 'rotateY(0deg)';
      };

      window.openZoom = function(type, event) {
        event.stopPropagation();
        playCyberSound('flip');
        let srcImg = '';
        if (type === 'wx') srcImg = document.getElementById('wxImg').src;
        else if (type === 'zfb') srcImg = document.getElementById('zfbImg').src;
        else if (type === 'gzh') srcImg = document.getElementById('gzhImg').src;
        if (!srcImg) return;
        document.getElementById('zoomModalImg').src = srcImg;
        document.getElementById('zoomModal').classList.add('active');
      };

      window.closeZoom = function() {
        playCyberSound('beep');
        document.getElementById('zoomModal').classList.remove('active');
      };

      // 动态加载数据
      fetchDonationData();
    }

    async function fetchDonationData() {
      const defaultConfig = {
        ds: "能量注入 ✦ 请作者喝杯冰可乐",
        img: { gzh: "https://cdn.jsdmirror.com/gh/cddldg/jst@main/img/20260622180316257.webp", zfb: "https://cdn.jsdmirror.com/gh/cddldg/jst@main/img/20260622180325546.webp", wx: "https://cdn.jsdmirror.com/gh/cddldg/jst@main/img/20260622180321160.webp" }
      };
      try {
        const response = await fetch('https://gitee.com/api/v5/repos/dldg/BatchJob/contents/cf.json');
        if (!response.ok) throw new Error('API error');
        const resJson = await response.json();
        const data = JSON.parse(decodeURIComponent(escape(atob(resJson.content))));
        updateDataSilent(data, defaultConfig);
      } catch (e) {
        try {
          const proxyUrl = 'https://api.allorigins.win/raw?url=' + encodeURIComponent('https://gitee.com/dldg/BatchJob/raw/master/cf.json');
          const proxyResponse = await fetch(proxyUrl);
          const proxyData = await proxyResponse.json();
          updateDataSilent(proxyData, defaultConfig);
        } catch (e2) {}
      }
    }

    function updateDataSilent(data, defaultConfig) {
      const dsText = data.ds || defaultConfig.ds;
      const imgObj = data.img || defaultConfig.img;
      const hintEl = document.getElementById('hintText');
      if (hintEl && hintEl.textContent !== dsText) hintEl.textContent = dsText;
      silentUpdateImage('wxImg', imgObj.wx);
      silentUpdateImage('zfbImg', imgObj.zfb);
      silentUpdateImage('gzhImg', imgObj.gzh);
    }

    function silentUpdateImage(imgId, newSrc) {
      const img = document.getElementById(imgId);
      if (!img || !newSrc || img.src === newSrc) return;
      let processedSrc = newSrc;
      if (newSrc.includes('gitee.com') && newSrc.includes('/raw/')) processedSrc = newSrc.replace('gitee.com/', 'dldg.gitee.io/').replace('/raw/', '/');
      const tempImg = new Image();
      tempImg.src = processedSrc;
      tempImg.onload = function() { img.src = processedSrc; };
    }

    window.openDonation = function() {
      loadWidget();
      document.getElementById('donation-modal').classList.add('is-open');
      document.body.style.overflow = 'hidden';
    };

    window.closeDonation = function() {
      document.getElementById('donation-modal').classList.remove('is-open');
      document.body.style.overflow = '';
    };

    document.addEventListener('click', function(e) {
      if (e.target.id === 'donation-close' || e.target.closest('#donation-close')) closeDonation();
      if (e.target.id === 'donation-backdrop') closeDonation();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeDonation();
    });

    document.addEventListener('astro:after-swap', function() {
      widgetLoaded = false;
      var root = document.getElementById('donation-widget-root');
      if (root) root.innerHTML = '';
    });
  })();
</script>
