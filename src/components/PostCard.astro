---
interface Props {
  title: string;
  description?: string;
  slug: string;
  tags?: string[];
  category?: string;
  cover?: string;
  pinned?: boolean;
  draft?: boolean;
  routePrefix?: string;
  collection?: string;
  routePrefixMap?: Record<string, string>;
}

const {
  title,
  description,
  slug,
  tags = [],
  category,
  cover,
  pinned = false,
  draft = false,
  routePrefix = '/post/',
  collection,
  routePrefixMap,
} = Astro.props;

const linkPrefix = collection && routePrefixMap?.[collection] ? routePrefixMap[collection] : routePrefix;
---

<article
  class="card-hover bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm overflow-hidden group"
  transition:animate="fade"
>
  <a href={`${linkPrefix}${slug}`} class="block">
    {cover ? (
      <div class="aspect-[2/1] overflow-hidden">
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="aspect-[2/1] bg-gradient-to-br from-primary/10 via-primary/5 to-transparent flex items-center justify-center overflow-hidden">
        <span class="text-4xl font-bold text-primary/20 group-hover:text-primary/30 transition-colors duration-500">
          {title.charAt(0)}
        </span>
      </div>
    )}

    <div class="p-4">
      <div class="flex items-center gap-2 mb-2">
        {category && (
          <span class="inline-block text-[10px] font-medium text-primary bg-primary/10 px-1.5 py-0.5 rounded-full">
            {category}
          </span>
        )}
        {pinned && (
          <span class="inline-flex items-center gap-0.5 text-[10px] font-medium text-amber-600 bg-amber-50 dark:bg-amber-900/20 dark:text-amber-400 px-1.5 py-0.5 rounded-full">
            <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            置顶
          </span>
        )}
        {draft && (
          <span class="inline-flex items-center gap-0.5 text-[10px] font-medium text-gray-500 bg-gray-100 dark:bg-gray-800 dark:text-gray-400 px-1.5 py-0.5 rounded-full">
            <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            编辑中
          </span>
        )}
      </div>

      <h2 class="text-sm font-semibold mb-1.5 group-hover:text-primary transition-colors line-clamp-2">
        {title}
      </h2>

      {description && (
        <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2 leading-relaxed">
          {description}
        </p>
      )}
    </div>
  </a>

  {tags.length > 0 && (
    <div class="px-5 pb-4 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <a
          href={`/tags/${tag}`}
          class="text-xs px-2 py-0.5 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:text-primary dark:hover:text-primary hover:bg-primary/5 dark:hover:bg-primary/10 transition-all"
        >
          {tag}
        </a>
      ))}
    </div>
  )}
</article>
