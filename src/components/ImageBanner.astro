---
import { BANNERS, BANNER_INTERVAL } from '../consts';

interface Props {
  banners?: typeof BANNERS;
}

const { banners = BANNERS } = Astro.props;
const count = banners.length;
---

<section class="carousel" aria-label="精选内容轮播" data-count={count} data-interval={BANNER_INTERVAL}>
  <!-- 粒子画布 -->
  <canvas class="carousel-particles" id="particle-canvas" aria-hidden="true"></canvas>

  <!-- 进度条 -->
  <div class="carousel-progress" id="carousel-progress">
    <span class="carousel-progress-bar" id="progress-bar"></span>
  </div>

  <!-- 幻灯片 -->
  <div class="carousel-track" id="carousel-track">
    {banners.map((banner, i) => (
      <a
        href={banner.link}
        class={`carousel-slide ${i === 0 ? 'active' : ''}`}
        data-index={i}
      >
        <img
          src={banner.image}
          alt={banner.title || `精选内容 ${i + 1}`}
          class="carousel-img"
          loading={i === 0 ? 'eager' : 'lazy'}
        />
        <div class="carousel-overlay"></div>
        <div class="carousel-content">
          {banner.title && (
            <span class="carousel-badge" id={`badge-${i}`}>#{banner.title}</span>
          )}
          <span class="carousel-cta">了解更多 &rarr;</span>
        </div>
      </a>
    ))}
  </div>

  <!-- 底部指示器 -->
  <div class="carousel-controls">
    <div class="carousel-dots" id="carousel-dots">
      {banners.map((_, i) => (
        <button
          class={`carousel-dot ${i === 0 ? 'active' : ''}`}
          data-index={i}
          aria-label={`第 ${i + 1} 张`}
        >
          <span class="carousel-dot-progress"></span>
        </button>
      ))}
    </div>
    <span class="carousel-index" id="carousel-index">01 / {String(count).padStart(2, '0')}</span>
  </div>
</section>

<script>
  function initCarousel() {
    const containers = document.querySelectorAll('.carousel');

    containers.forEach((container) => {
      const track = container.querySelector<HTMLElement>('#carousel-track');
      const slides = container.querySelectorAll<HTMLElement>('.carousel-slide');
      const dots = container.querySelectorAll<HTMLElement>('.carousel-dot');
      const indexEl = container.querySelector<HTMLElement>('#carousel-index');
      const progressBar = container.querySelector<HTMLElement>('#progress-bar');
      const canvas = container.querySelector<HTMLCanvasElement>('#particle-canvas');

      if (!track || slides.length <= 1) return;

      const count = slides.length;
      const intervalMs = parseInt(container.getAttribute('data-interval') || '5') * 1000;
      let currentIndex = 0;
      let rafId: number | null = null;
      let startTime = 0;
      let paused = false;

      // ========== 粒子系统 ==========
      let particles: { x: number; y: number; vx: number; vy: number; r: number; o: number }[] = [];
      let ctx: CanvasRenderingContext2D | null = null;

      function resizeCanvas() {
        if (!canvas || !container) return;
        const rect = container.getBoundingClientRect();
        const dpr = window.devicePixelRatio || 1;
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        canvas.style.width = rect.width + 'px';
        canvas.style.height = rect.height + 'px';
        ctx = canvas.getContext('2d');
        if (ctx) ctx.scale(dpr, dpr);
        initParticles(rect.width, rect.height);
      }

      function initParticles(w: number, h: number) {
        particles = [];
        const num = Math.floor((w * h) / 15000);
        for (let i = 0; i < num; i++) {
          particles.push({
            x: Math.random() * w,
            y: Math.random() * h,
            vx: (Math.random() - 0.5) * 0.3,
            vy: (Math.random() - 0.5) * 0.3,
            r: Math.random() * 1.5 + 0.5,
            o: Math.random() * 0.4 + 0.1,
          });
        }
      }

      function drawParticles() {
        if (!ctx || !canvas || paused) return;
        const w = canvas.clientWidth;
        const h = canvas.clientHeight;
        ctx.clearRect(0, 0, w, h);

        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0) p.x = w;
          if (p.x > w) p.x = 0;
          if (p.y < 0) p.y = h;
          if (p.y > h) p.y = 0;

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255,255,255,${p.o})`;
          ctx.fill();
        }

        requestAnimationFrame(drawParticles);
      }

      // ========== 轮播逻辑 ==========
      function goToSlide(index: number) {
        slides[currentIndex].classList.remove('active');
        const prevDot = dots[currentIndex];

        currentIndex = index;

        slides[currentIndex].classList.add('active');
        dots[currentIndex].classList.add('active');
        prevDot.classList.remove('active');

        if (indexEl) {
          indexEl.textContent = `${String(currentIndex + 1).padStart(2, '0')} / ${String(count).padStart(2, '0')}`;
        }

        // 重置进度
        if (progressBar) progressBar.style.width = '0%';
        if (rafId) cancelAnimationFrame(rafId);
        startTime = performance.now();

        // dot 进度重置
        dots.forEach((d, i) => {
          const dp = d.querySelector<HTMLElement>('.carousel-dot-progress');
          if (dp) dp.style.width = i === currentIndex ? '0%' : '0%';
        });

        updateProgress();
      }

      function nextSlide() {
        goToSlide((currentIndex + 1) % count);
      }

      function updateProgress() {
        if (paused) return;
        const elapsed = performance.now() - startTime;
        const progress = Math.min((elapsed / intervalMs) * 100, 100);

        if (progressBar) progressBar.style.width = progress + '%';

        const activeDot = dots[currentIndex];
        if (activeDot) {
          const dp = activeDot.querySelector<HTMLElement>('.carousel-dot-progress');
          if (dp) dp.style.width = progress + '%';
        }

        if (progress >= 100) {
          nextSlide();
        } else {
          rafId = requestAnimationFrame(updateProgress);
        }
      }

      function startAuto() {
        stopAuto();
        startTime = performance.now();
        if (progressBar) progressBar.style.width = '0%';
        updateProgress();
      }

      function stopAuto() {
        if (rafId) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
      }

      function pause() {
        paused = true;
        stopAuto();
      }

      function resume() {
        if (!paused) return;
        paused = false;
        startTime = performance.now();
        updateProgress();
        drawParticles();
      }

      // ========== 事件绑定 ==========
      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          goToSlide(i);
          startAuto();
        });
      });

      container.addEventListener('mouseenter', () => {
        stopAuto();
      });
      container.addEventListener('mouseleave', () => {
        startAuto();
      });

      // 粒子在鼠标悬停时暂停/恢复
      container.addEventListener('mouseenter', pause);
      container.addEventListener('mouseleave', resume);

      // 触摸事件
      let touchStartX = 0;
      container.addEventListener('touchstart', (e) => {
        touchStartX = (e as TouchEvent).touches[0].clientX;
        stopAuto();
      }, { passive: true });
      container.addEventListener('touchend', (e) => {
        const diff = touchStartX - (e as TouchEvent).changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
          goToSlide(diff > 0 ? (currentIndex + 1) % count : (currentIndex - 1 + count) % count);
        }
        startAuto();
      });

      // ========== 启动 ==========
      resizeCanvas();
      drawParticles();
      startAuto();

      // 窗口大小变化时重设 canvas
      window.addEventListener('resize', resizeCanvas);
    });
  }

  document.addEventListener('astro:page-load', initCarousel);
  initCarousel();
</script>
