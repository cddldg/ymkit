---
import DonationModal from './DonationModal.astro';

const startYear = 2026;
---

<footer class="border-t border-gray-200/50 dark:border-gray-700/50 mt-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-2 text-sm text-gray-500 dark:text-gray-400">
            <span>&copy; {startYear} 一秒工具</span>
            <span class="hidden sm:inline text-gray-300 dark:text-gray-600">|</span>
            <a href="https://www.ymkit.cn/" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">YMKit</a>
            <span>&</span>
            <button id="donate-trigger" class="text-cyan-500 hover:underline cursor-pointer bg-transparent border-none text-sm p-0">打赏</button>
        </div>
    </div>
</footer>

<DonationModal />

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('donate-trigger');
    if (btn) btn.addEventListener('click', openDonation);
  });
  document.addEventListener('astro:after-swap', function() {
    var btn = document.getElementById('donate-trigger');
    if (btn) btn.addEventListener('click', openDonation);
  });
</script>
