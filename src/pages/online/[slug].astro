---
import SEO from '../../components/SEO.astro';
import DonationModal from '../../components/DonationModal.astro';
import onlineTools from '../../data/online';
import donationCss from '../../styles/donation.css?raw';
import donationModalCss from '../../styles/donation-modal.css?raw';

export function getStaticPaths() {
  return onlineTools.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const tool = onlineTools.find((t) => t.slug === slug);
if (!tool) return Astro.redirect('/404');

const htmlModules = import.meta.glob('/src/data/online/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const htmlContent = htmlModules[`/src/data/online/${slug}.html`];
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={tool.title} description={tool.description} />
    <style is:inline set:html={donationModalCss + donationCss} />
    <style is:inline>
      /* 覆盖打赏弹窗为右上角固定面板 */
      #donation-modal {
        position: fixed !important;
        inset: auto !important;
        top: 16px !important;
        right: 16px !important;
        bottom: auto !important;
        left: auto !important;
        display: block !important;
        z-index: 50 !important;
        max-width: 380px;
        width: auto;
        pointer-events: auto;
      }
      #donation-modal .is-open { display: block !important; }
      #donation-backdrop { display: none !important; }
      #donation-modal-body {
        position: static !important;
        transform: none !important;
        max-width: 380px !important;
        width: 380px !important;
        max-height: 85vh !important;
        overflow-y: auto !important;
        border-radius: 16px !important;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5) !important;
      }
      #donation-close { position: absolute !important; top: 12px !important; right: 12px !important; }
      /* 隐藏弹窗时不占空间 */
      #donation-modal:not(.is-open) { display: none !important; }
      /* 响应式：小屏幕占更少空间 */
      @media (max-width: 480px) {
        #donation-modal { top: 8px !important; right: 8px !important; max-width: 300px; }
        #donation-modal-body { width: 300px !important; max-height: 70vh !important; }
      }
    </style>
  </head>
  <body>
    <div set:html={htmlContent} class="min-h-screen text-slate-100 flex flex-col lg:flex-row overflow-x-hidden" />

    <!-- 右上角打赏按钮（默认隐藏，关闭弹窗后显示） -->
    <button
      id="donation-trigger"
      onclick="openDonation(); this.classList.add('hidden');"
      class="hidden fixed top-4 right-4 z-50 flex items-center gap-1.5 px-4 py-2.5 rounded-xl bg-slate-900/80 backdrop-blur-md border border-slate-700 text-slate-300 hover:text-primary hover:border-primary text-sm font-medium transition-all cursor-pointer shadow-lg"
      title="打赏"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
      </svg>
      打赏
    </button>

    <DonationModal />

    <script is:inline>
      // 等原生 openDonation 定义后，包装一下：调用原逻辑，但不要锁 body 滚动
      var _timer = setInterval(function() {
        if (typeof window.openDonation === 'function') {
          clearInterval(_timer);
          var _origOpen = window.openDonation;
          window.openDonation = function() {
            _origOpen();
            document.body.style.overflow = ''; // 面板不锁滚动
            document.getElementById('donation-trigger').classList.add('hidden');
          };
          var _origClose = window.closeDonation;
          window.closeDonation = function() {
            _origClose();
            document.body.style.overflow = '';
            document.getElementById('donation-trigger').classList.remove('hidden');
          };
          // 自动打开
          openDonation();
        }
      }, 100);
    </script>
  </body>
</html>
