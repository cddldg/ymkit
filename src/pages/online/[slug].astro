---
import SEO from '../../components/SEO.astro';
import DonationModal from '../../components/DonationModal.astro';
import onlineTools from '../../data/online';
import donationCss from '../../styles/donation.css?raw';
import donationModalCss from '../../styles/donation-modal.css?raw';

export function getStaticPaths() {
  return onlineTools.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const tool = onlineTools.find((t) => t.slug === slug);
if (!tool) return Astro.redirect('/404');

const htmlModules = import.meta.glob('/src/data/online/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const htmlContent = htmlModules[`/src/data/online/${slug}.html`];
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={tool.title} description={tool.description} />
    <style is:inline set:html={donationModalCss + donationCss} />
  </head>
  <body>
    <div set:html={htmlContent} class="min-h-screen text-slate-100 flex flex-col lg:flex-row overflow-x-hidden" />

    <!-- 右上角打赏按钮（默认隐藏，关闭弹窗后显示） -->
    <button
      id="donation-trigger"
      onclick="openDonation(); this.classList.add('hidden');"
      class="hidden fixed top-4 right-4 z-50 flex items-center gap-1.5 px-4 py-2.5 rounded-xl bg-slate-900/80 backdrop-blur-md border border-slate-700 text-slate-300 hover:text-primary hover:border-primary text-sm font-medium transition-all cursor-pointer shadow-lg"
      title="打赏"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
      </svg>
      打赏
    </button>

    <DonationModal />

    <script is:inline>
      // 监听打赏弹窗关闭 → 显示按钮
      const observer = new MutationObserver(function() {
        const modal = document.getElementById('donation-modal');
        const btn = document.getElementById('donation-trigger');
        if (modal && btn && !modal.classList.contains('is-open')) {
          btn.classList.remove('hidden');
        }
      });
      // 页面加载后自动打开打赏弹窗，并开始监听
      setTimeout(function() {
        openDonation();
        const modal = document.getElementById('donation-modal');
        if (modal) observer.observe(modal, { attributes: true, attributeFilter: ['class'] });
      }, 500);
    </script>
  </body>
</html>
