---
import SEO from '../../components/SEO.astro';
import DonationModal from '../../components/DonationModal.astro';
import onlineTools from '../../data/online';
import donationCss from '../../styles/donation.css?raw';
import donationModalCss from '../../styles/donation-modal.css?raw';

export function getStaticPaths() {
  return onlineTools.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const tool = onlineTools.find((t) => t.slug === slug);
if (!tool) return Astro.redirect('/404');

const htmlModules = import.meta.glob('/src/data/online/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const htmlContent = htmlModules[`/src/data/online/${slug}.html`];
const wrapperClass = slug === 'gzh'
  ? 'min-h-screen flex flex-col lg:flex-row overflow-x-hidden'
  : 'h-screen overflow-hidden';
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={tool.title} description={tool.description} />
    <style is:inline set:html={donationModalCss + donationCss} />
    <style is:inline>
      /* 覆盖打赏弹窗为右上角固定面板 */
      #donation-modal {
        position: fixed !important;
        inset: auto !important;
        top: 16px !important;
        right: 16px !important;
        bottom: auto !important;
        left: auto !important;
        display: block !important;
        z-index: 50 !important;
        max-width: 380px;
        width: auto;
        pointer-events: auto;
      }
      #donation-modal .is-open { display: block !important; }
      #donation-backdrop { display: none !important; }
      #donation-modal-body {
        position: static !important;
        transform: none !important;
        max-width: 380px !important;
        width: 380px !important;
        max-height: 85vh !important;
        overflow-y: auto !important;
        border-radius: 16px !important;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5) !important;
      }
      #donation-close { position: absolute !important; top: 12px !important; right: 12px !important; }
      /* 隐藏弹窗时不占空间 */
      #donation-modal:not(.is-open) { display: none !important; }
      /* 响应式：小屏幕占更少空间 */
      @media (max-width: 480px) {
        #donation-modal { top: 8px !important; right: 8px !important; max-width: 300px; }
        #donation-modal-body { width: 300px !important; max-height: 70vh !important; }
      }
    </style>
  </head>
  <body>
    <div set:html={htmlContent} class={wrapperClass} />

    <DonationModal />
  </body>
</html>
