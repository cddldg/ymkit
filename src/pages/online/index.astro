---
import BlogLayout from '../../layouts/BlogLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import onlineTools from '../../data/online';
---

<BlogLayout
  title="在线工具"
  description="实用在线工具，打开即用"
>
  <Breadcrumb collection="online" />
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold flex items-center gap-2">
      <span class="w-1 h-6 bg-primary rounded-full inline-block"></span>
      在线工具
    </h1>
    <button
      onclick="openDonation()"
      class="flex items-center gap-1.5 px-4 py-2 rounded-xl bg-primary/10 hover:bg-primary/20 text-primary text-sm font-medium transition-colors cursor-pointer border-none"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
      </svg>
      打赏
    </button>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      onlineTools.map((tool) => (
        <a
          href={`/online/${tool.slug}`}
          target="_blank"
          class="group block p-6 rounded-2xl bg-white dark:bg-[var(--color-card-dark)] border-l-4 border-l-primary shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300"
        >
          <h2 class="text-lg font-bold mb-2 group-hover:text-primary transition-colors">{tool.title}</h2>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">{tool.description}</p>
          <span class="inline-flex items-center gap-1 text-xs text-primary opacity-0 group-hover:opacity-100 transition-opacity">
            打开工具 <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H19m0 0v5.5m0-5.5l-7 7"/></svg>
          </span>
        </a>
      ))
    }
  </div>
</BlogLayout>
