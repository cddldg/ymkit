---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.vue';
import Footer from '../../components/Footer.astro';
import Reward from '../../components/Reward.astro';
import ToolCard from '../../components/ToolCard.astro';
import toolsData from '../../data/tools.json';

export function getStaticPaths() {
  return toolsData.map((tool) => ({
    params: { id: tool.id },
    props: { tool },
  }));
}

const { tool } = Astro.props;

// Get related tools (same category, excluding current)
const relatedTools = toolsData
  .filter(t => t.category === tool.category && t.id !== tool.id)
  .slice(0, 4);

const categoryLabels: Record<string, string> = {
  chat: 'AI对话',
  image: 'AI绘画',
  code: 'AI编程',
  video: 'AI视频',
  writing: 'AI写作',
  audio: 'AI语音',
  productivity: '效率工具',
  search: 'AI搜索',
  design: 'AI设计'
};
---

<Layout title={tool.name} description={tool.description}>
  <Navbar client:load />

  <main class="tool-detail">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">首页</a>
        <span class="separator">/</span>
        <a href="/tools">AI工具</a>
        <span class="separator">/</span>
        <a href={`/tools?category=${tool.category}`}>{categoryLabels[tool.category] || tool.category}</a>
        <span class="separator">/</span>
        <span class="current">{tool.name}</span>
      </nav>

      <div class="detail-layout">
        <!-- Main Content -->
        <div class="main-content">
          <!-- Tool Header -->
          <div class="tool-header">
            <div class="tool-icon-large">
              <img src={tool.icon} alt={tool.name} />
            </div>
            <div class="tool-meta">
              <h1 class="tool-title">{tool.name}</h1>
              <div class="tool-badges">
                <span class="badge category">{categoryLabels[tool.category] || tool.category}</span>
                {tool.featured && <span class="badge featured">精选</span>}
                {tool.rating && (
                  <span class="badge rating">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="12" height="12">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    {tool.rating.toFixed(1)}
                  </span>
                )}
              </div>
            </div>
          </div>

          <!-- CTA Button -->
          <a href={tool.url} target="_blank" rel="noopener noreferrer" class="cta-button">
            <span>访问 {tool.name}</span>
            <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>

          <!-- Description -->
          <div class="content-section">
            <h2>工具介绍</h2>
            <p class="tool-description">{tool.description}</p>
          </div>

          <!-- Tags -->
          <div class="content-section">
            <h2>标签</h2>
            <div class="tags-list">
              {tool.tags.map((tag) => (
                <a href={`/tools?tag=${tag}`} class="tag-link">{tag}</a>
              ))}
            </div>
          </div>

          <!-- Reward Section -->
          <div class="content-section reward-section">
            <h2>支持我们</h2>
            <p>如果这个工具对你有帮助，欢迎打赏支持</p>
            <Reward />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="sidebar">
          <div class="sidebar-card">
            <h3>相关工具</h3>
            <div class="related-tools">
              {relatedTools.map((related) => (
                <a href={`/tools/${related.id}`} class="related-tool">
                  <div class="related-icon">
                    <img src={related.icon} alt={related.name} loading="lazy" />
                  </div>
                  <div class="related-info">
                    <span class="related-name">{related.name}</span>
                    <span class="related-category">{categoryLabels[related.category] || related.category}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .tool-detail {
    margin-top: 64px;
    padding: 2rem 0;
    min-height: calc(100vh - 64px);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 2rem;
    font-size: 0.875rem;
    color: #64748b;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: #3b82f6;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: #2563eb;
  }

  .separator {
    color: #cbd5e1;
  }

  .current {
    color: #0f172a;
    font-weight: 500;
  }

  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
  }

  .main-content {
    min-width: 0;
  }

  .tool-header {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .tool-icon-large {
    width: 80px;
    height: 80px;
    border-radius: 20px;
    overflow: hidden;
    flex-shrink: 0;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
  }

  .tool-icon-large img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tool-title {
    font-size: 2rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.75rem;
  }

  .tool-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .badge.category {
    background: #f1f5f9;
    color: #475569;
  }

  .badge.featured {
    background: #fef3c7;
    color: #92400e;
  }

  .badge.rating {
    background: #fef3c7;
    color: #92400e;
  }

  .cta-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    color: white;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    margin-bottom: 2rem;
  }

  .cta-button:hover {
    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
    box-shadow: 0 20px 25px -5px rgba(59, 130, 246, 0.3);
    transform: translateY(-2px);
  }

  .content-section {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid #e2e8f0;
  }

  .content-section h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .tool-description {
    font-size: 1rem;
    color: #334155;
    line-height: 1.75;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-link {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    background: #f1f5f9;
    color: #475569;
    border-radius: 8px;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .tag-link:hover {
    background: #e2e8f0;
    color: #0f172a;
  }

  .reward-section p {
    font-size: 0.875rem;
    color: #64748b;
    margin-bottom: 1rem;
  }

  .sidebar {
    position: sticky;
    top: 80px;
    align-self: flex-start;
  }

  .sidebar-card {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
  }

  .sidebar-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .related-tools {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .related-tool {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 12px;
    transition: all 0.2s ease;
    text-decoration: none;
    color: inherit;
  }

  .related-tool:hover {
    background: #f8fafc;
  }

  .related-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    background: #f1f5f9;
  }

  .related-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .related-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #0f172a;
    display: block;
    margin-bottom: 2px;
  }

  .related-category {
    font-size: 0.75rem;
    color: #64748b;
  }

  @media (max-width: 1024px) {
    .detail-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .tool-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .tool-badges {
      justify-content: center;
    }

    .tool-title {
      font-size: 1.5rem;
    }
  }
</style>
