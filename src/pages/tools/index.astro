---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.vue';
import Footer from '../../components/Footer.astro';
import ToolsPage from '../../components/ToolsPage.vue';
---

<Layout title="AI工具库">
  <Navbar client:load />

  <main class="tools-main">
    <div class="container">
      <div class="page-header">
        <h1 class="page-title">AI工具库</h1>
        <p class="page-desc">发现最好用的AI工具，提升工作效率</p>
      </div>

      <ToolsPage client:load />
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .tools-main {
    margin-top: 64px;
    padding: 3rem 0;
    min-height: calc(100vh - 64px);
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.75rem;
  }

  .page-desc {
    font-size: 1.125rem;
    color: #64748b;
  }
</style>
